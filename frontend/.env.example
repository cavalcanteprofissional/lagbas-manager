# Variáveis Obrigatórias
FLASK_SECRET_KEY=your-secret-key-here
SUPABASE_URL=https://your-project.supabase.co

# Desenvolvimento Local (não usar na Vercel)
SUPABASE_KEY=your-supabase-publishable-key-here
SUPABASE_SERVICE_KEY=your-supabase-service-key-here

# Vercel usa estes nomes (não usar no desenvolvimento local)
# SUPABASE_ANON_KEY=your-supabase-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Configurações Opcionais
# INACTIVITY_TIMEOUT_MINUTES=10  # Timeout de sessão (padrão: 10 min)
# ITEMS_PER_PAGE=10              # Itens por página (padrão: 10)
# ALLOWED_ORIGINS=*              # Origens permitidas para CORS (padrão: *)
# LITROS_EQUIVALENTES_KG=956.0  # Litros por kg de gás (padrão: 956.0)
# GAS_KG_DEFAULT=1.0            # Kg padrão de gás (padrão: 1.0)
# CUSTO_DEFAULT=290.00         # Custo padrão (padrão: 290.00)